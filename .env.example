# Local PostgreSQL connection for Arina.
# Copy this file to .env and replace YOUR_PASSWORD with your local postgres password.
ARINA_DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/arina_db
ARINA_DATABASE_SCHEMA=arina

# Public base URL used in email activation links.
ARINA_PUBLIC_BASE_URL=http://localhost:5000

# Optional Flask secret for future auth sessions/tokens.
ARINA_SECRET_KEY=change-me-local-secret

# SMTP settings for sending activation emails.
# Leave empty during local development. If empty, the activation link is printed in the server console and returned in dev response.
ARINA_SMTP_HOST=
ARINA_SMTP_PORT=587
ARINA_SMTP_USER=
ARINA_SMTP_PASSWORD=
ARINA_SMTP_FROM=
ARINA_SMTP_USE_TLS=true
